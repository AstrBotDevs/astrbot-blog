---
import BaseHead from '../components/BaseHead.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts'
import { languages, normalizeLang, type Lang } from '../i18n/config'

interface Props {
	title?: string
	description?: string
	lang?: Lang
}

const { title, description } = Astro.props
const lang = normalizeLang(Astro.props.lang ?? Astro.currentLocale)

import '@fontsource-variable/inter'
import '@fontsource-variable/jetbrains-mono'
---

<!doctype html>
<html lang={languages[lang].htmlLang}>
	<head>
		<BaseHead
			title={title || SITE_TITLE}
			description={description || SITE_DESCRIPTION}
			lang={lang}
		/>
	</head>
	<body
		class="text-foreground bg-background font-light dark:text-foreground-dark dark:bg-background-dark transition-colors"
	>
		<Navbar title={SITE_TITLE} lang={lang} />
		<slot />
		<Footer lang={lang} />
	</body>
</html>
