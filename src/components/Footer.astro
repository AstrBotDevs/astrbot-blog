---
import { SocialLinks } from '../consts'
import { Icon } from 'astro-icon/components'
import { localizedPath, normalizeLang } from '../i18n/config'
import { useTranslations } from '../i18n/ui'

const today = new Date()
const lang = normalizeLang(Astro.props.lang ?? Astro.currentLocale)
const t = useTranslations(lang)
const links = [
	{ name: t.blog, url: localizedPath(lang, '/blog') },
	{ name: t.about, url: localizedPath(lang, '/about') },
]
---

<footer>
	<div
		class="app-container grid md:grid-cols-3 gap-12 py-16 border-t-2 border-foreground/50 dark:border-foreground-dark/50"
	>
		<div>
			<a href={localizedPath(lang, '/')} class="block w-fit" aria-label={t.home}>
				<img src="/astrbot-icon.png" alt="AstrBot" class="h-9 w-9" />
			</a>
		</div>
		<div>
			<h3 class="font-semibold text-2xl">Links</h3>
			<div class="flex flex-wrap gap-4 mt-4">
				{
					links.map((link) => (
						<a
							class="text-lg"
							href={link.url}
						>
							{link.name}
						</a>
					))
				}
				<a
					href={localizedPath(lang, '/rss.xml')}
					target="_blank"
					rel="noopener noreferrer"
					class="text-lg"
					aria-label="RSS Feed"
				>
					<Icon name="mdi:rss" class="w-6 h-6" />
				</a>
			</div>
		</div>
		<div>
			<h3 class="font-semibold text-2xl">Socials</h3>
			<div class="flex flex-wrap gap-4 mt-4">
				{
					SocialLinks.map((link) => (
						<a
							class="text-lg"
							href={link.url}
							target="_blank"
							rel="noopener noreferrer"
						>
							{link.name}
						</a>
					))
				}
			</div>
		</div>
	</div>
	<div class="app-container flex justify-between items-center pb-6 text-center">
		<p class="text-left md:text-center w-full">
			&copy; {today.getFullYear()} {t.sourceCode} <a
				class="underline"
				href="https://github.com/AstrBotDevs/astrbot-blog"
				target="_blank">GitHub</a
			>
		</p>
	</div>
</footer>
